# ── REQUIRED ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN
PORT=8000

# ── CORS: add your live frontend URL here ────────────────────
CORS_ORIGINS=http://localhost:3000,https://ji-ledger-frontend.onrender.com,https://yourdomain.com

# ── OPTIONAL: MongoDB for market data (leave blank to use fallback) ──
MONGODB_URI=

# ── OPTIONAL: Razorpay (add after account creation) ─────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── OPTIONAL: Custom domain ──────────────────────────────────
FRONTEND_URL=https://yourdomain.com
